# ─── Files/dirs NOT needed in published VSIX ─────────────────────────────────
# Webpack bundles everything into dist/, so source & deps are NOT needed.

# Source code (webpack output replaces these)
src/
webview/
webpack.config.js
tsconfig.json

# Dependencies (bundled by webpack)
node_modules/

# Development & CI
.github/
.vscode/
.eslintrc*
**/*.test.ts
**/*.spec.ts
*.log

# Build artifacts & releases
*.vsix
*.sqlite3
releases/

# Platform noise
.DS_Store
Thumbs.db

# Internal docs (not for end users)
docs/
.lhub_docs/

# Source maps (optional — remove if you want debugging in production)
# *.map
